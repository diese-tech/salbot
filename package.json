{
  "name": "salbot",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "corepack pnpm -r --if-present test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:types": "pnpm --filter @salbot/db generate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
